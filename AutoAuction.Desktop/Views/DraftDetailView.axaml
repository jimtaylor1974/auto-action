<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoAuction.Desktop.ViewModels"
             xmlns:models="using:AutoAuction.Core.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="800"
             x:Class="AutoAuction.Desktop.Views.DraftDetailView"
             x:DataType="vm:DraftDetailViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ===== Header / actions bar (always visible) ===== -->
        <Border Grid.Row="0" Padding="16,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <Button Grid.Column="0" Command="{Binding BackCommand}"
                        ToolTip.Tip="Back to Home" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="ArrowLeft" Width="18" Height="18"/>
                        <TextBlock Text="Back" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Command="{Binding GenerateWithAiCommand}" Classes="accent"
                        Margin="8,0,0,0" ToolTip.Tip="Generate listing fields from the photos with AI"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="Creation" Width="16" Height="16"
                                         Classes.spin="{Binding IsGenerating}"/>
                        <TextBlock Text="Draft with AI" FontSize="12"
                                   IsVisible="{Binding !IsGenerating}"/>
                        <TextBlock Text="Generating…" FontSize="12"
                                   IsVisible="{Binding IsGenerating}"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="3" Command="{Binding MarkListedCommand}" Classes="accent"
                        Margin="0,0,8,0" ToolTip.Tip="Move this draft into Listed" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="PackageVariantClosedCheck" Width="16" Height="16"/>
                        <TextBlock Text="Mark as Listed" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Margin="0,0,8,0"
                        ToolTip.Tip="Move this draft's photos back to the inbox and delete the draft"
                        Padding="6,4">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Spacing="10" MaxWidth="260">
                                <TextBlock TextWrapping="Wrap"
                                           Text="Discard this draft? Its photos will be moved back to the inbox and the draft details will be permanently deleted."/>
                                <Button Command="{Binding DiscardCommand}"
                                        HorizontalAlignment="Right" Classes="accent">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="DeleteOutline" Width="16" Height="16"/>
                                        <TextBlock Text="Discard draft"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="DeleteOutline" Width="16" Height="16"/>
                        <TextBlock Text="Discard" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" Command="{Binding OpenFolderCommand}"
                        ToolTip.Tip="Open this draft's folder in your file manager" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                        <TextBlock Text="Open folder" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== Editor form ===== -->
        <ScrollViewer Grid.Row="1" Padding="24,16">
            <!-- Bottom margin keeps the last control clear of the window edge so the scroll
                 extent reaches it. -->
            <StackPanel MaxWidth="640" HorizontalAlignment="Left" Spacing="2"
                        Margin="0,0,0,48">

                <!-- Attached images -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Images}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DraftImageViewModel">
                                <Border Width="110" Height="110" CornerRadius="4"
                                        ClipToBounds="True" Background="#22000000">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                           ToolTip.Tip="{Binding FileName}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="No images attached to this draft."
                           Opacity="0.5" FontSize="12"
                           IsVisible="{Binding !Images.Count}"/>

                <!-- Save status -->
                <TextBlock Text="{Binding SaveStatus}" FontSize="11" Opacity="0.6" Margin="0,8,0,0"/>

                <!-- AI error -->
                <TextBlock Text="{Binding AiError}" Foreground="#D13438" FontSize="12"
                           TextWrapping="Wrap" Margin="0,8,0,0"
                           IsVisible="{Binding AiError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- AI live log -->
                <Border IsVisible="{Binding ShowGenerationLog}" Margin="0,8,0,0" Padding="10"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}">
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <mi:MaterialIcon Grid.Column="0" Kind="Creation" Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Classes.spin="{Binding IsGenerating}"/>
                            <TextBlock Grid.Column="1" Text="AI activity" FontWeight="SemiBold" FontSize="12"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Click="OnCopyLogClick" Padding="6,2"
                                    Background="Transparent" ToolTip.Tip="Copy the log for troubleshooting">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <mi:MaterialIcon Kind="ContentCopy" Width="13" Height="13"/>
                                    <TextBlock Text="Copy" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GenerationLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="sys:String">
                                        <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas,monospace"
                                                   TextWrapping="Wrap" Opacity="0.85"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- AI preview: proposed fields awaiting Apply / Discard -->
                <Border IsVisible="{Binding HasAiPreview}" Margin="0,8,0,0" Padding="14"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemAccentColor}"
                        Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}">
                    <StackPanel Spacing="6" DataContext="{Binding AiPreview}"
                                x:DataType="vm:AiPreviewViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Creation" Width="16" Height="16"/>
                            <TextBlock Text="AI suggestion — review and apply" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding CategoryDisplay}" FontSize="12" Opacity="0.8" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PriceSummary}" FontSize="12" Opacity="0.8"/>
                        <TextBlock Text="{Binding ShippingSummary}" FontSize="12" Opacity="0.8"/>
                        <TextBlock Text="{Binding Condition, StringFormat='Condition: {0}'}" FontSize="12" Opacity="0.8"/>
                        <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                   MaxHeight="120" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="Apply"
                                    Command="{Binding $parent[UserControl].((vm:DraftDetailViewModel)DataContext).ApplyAiCommand}"
                                    Classes="accent"/>
                            <Button Content="Discard"
                                    Command="{Binding $parent[UserControl].((vm:DraftDetailViewModel)DataContext).DiscardAiCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- AI image analysis (factual description; not sent to TradeMe) -->
                <Expander Header="AI image analysis" Margin="0,8,0,0"
                          IsExpanded="{Binding HasAiPreview}">
                    <TextBox Text="{Binding Listing.AiImageDescription}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                             Watermark="Run “Draft with AI” to generate a factual description of the photos."/>
                </Expander>

                <!-- ===== Core Details ===== -->
                <TextBlock Text="Core Details" Classes="section"/>

                <TextBlock Text="Title (required, max 50)" Classes="label"/>
                <TextBox Text="{Binding Listing.Title}" MaxLength="50"
                         Watermark="e.g. Nike Air Max 90 - Mens Size 10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
                    <TextBlock Text="{Binding Listing.Title.Length}" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="/50" FontSize="11" Opacity="0.6"/>
                </StackPanel>

                <TextBlock Text="Subtitle (optional, max 50)" Classes="label"/>
                <TextBox Text="{Binding Listing.Subtitle}" MaxLength="50"/>

                <TextBlock Text="Category ID (required)" Classes="label"/>
                <TextBox Text="{Binding Listing.CategoryId}"
                         Watermark="e.g. 0153-0447-0818-"/>
                <TextBlock Text="{Binding CategoryPathDisplay}" FontSize="12" Opacity="0.7"
                           TextWrapping="Wrap" Margin="0,2,0,0"
                           IsVisible="{Binding CategoryPathDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <TextBlock Text="Condition (required)" Classes="label"/>
                <ComboBox ItemsSource="{Binding ConditionOptions}"
                          SelectedItem="{Binding Listing.Condition}"
                          HorizontalAlignment="Left" MinWidth="160"/>

                <TextBlock Text="Description (required)" Classes="label"/>
                <TextBox Text="{Binding Listing.Description}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="120" Watermark="Describe the item. One paragraph per line."/>

                <!-- ===== Pricing ===== -->
                <TextBlock Text="Pricing" Classes="section"/>

                <StackPanel Orientation="Horizontal" Spacing="24">
                    <CheckBox Content="Run an auction" IsChecked="{Binding Listing.IsAuction}"/>
                    <CheckBox Content="Set a Buy Now price" IsChecked="{Binding Listing.HasBuyNow}"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Start price" Classes="label"/>
                        <NumericUpDown Value="{Binding Listing.StartPrice}"
                                       Minimum="0" Increment="1" FormatString="0.00"
                                       IsEnabled="{Binding Listing.IsAuction}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Reserve price (optional)" Classes="label"/>
                        <NumericUpDown Value="{Binding Listing.ReservePrice}"
                                       Minimum="0" Increment="1" FormatString="0.00"
                                       IsEnabled="{Binding Listing.IsAuction}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Buy Now price" Classes="label"/>
                        <NumericUpDown Value="{Binding Listing.BuyNowPrice}"
                                       Minimum="0" Increment="1" FormatString="0.00"
                                       IsEnabled="{Binding Listing.HasBuyNow}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Allow buyers to make an offer" Margin="0,6,0,0"
                          IsChecked="{Binding Listing.AllowOffers}"/>

                <TextBlock Text="Duration (days)" Classes="label"/>
                <ComboBox ItemsSource="{Binding DurationOptions}"
                          SelectedItem="{Binding Listing.DurationDays}"
                          HorizontalAlignment="Left" MinWidth="120"/>

                <!-- ===== Shipping ===== -->
                <TextBlock Text="Shipping &amp; Logistics" Classes="section"/>

                <TextBlock Text="Shipping method" Classes="label"/>
                <ComboBox ItemsSource="{Binding ShippingMethodOptions}"
                          SelectedItem="{Binding Listing.Shipping}"
                          HorizontalAlignment="Left" MinWidth="200"/>

                <StackPanel IsVisible="{Binding IsSpecifyShipping}" Spacing="6"
                            Margin="0,6,0,0">
                    <TextBlock Text="Custom shipping options" Classes="label"/>
                    <TextBlock Text="No options yet — click &quot;Add shipping option&quot; below. Each row must be unique by Region + Rural (e.g. New Zealand / Urban and New Zealand / Rural for two nationwide rates)."
                               FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                               IsVisible="{Binding !Listing.ShippingOptions.Count}"/>
                    <Grid ColumnDefinitions="170,*,130,Auto,Auto" Margin="0,2,0,0"
                          IsVisible="{Binding !!Listing.ShippingOptions.Count}">
                        <TextBlock Grid.Column="0" Text="Cost" FontSize="11" Opacity="0.6" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="Region" FontSize="11" Opacity="0.6" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="Rural" FontSize="11" Opacity="0.6" Margin="0,0,8,0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Listing.ShippingOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ShippingOption">
                                <Grid ColumnDefinitions="170,*,130,Auto,Auto" Margin="0,0,0,6">
                                    <NumericUpDown Grid.Column="0" Value="{Binding Price}"
                                                   Minimum="0" Increment="0.5" FormatString="C2"
                                                   Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" Margin="0,0,8,0" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding $parent[ItemsControl].((vm:DraftDetailViewModel)DataContext).RegionOptions}"
                                              SelectedValueBinding="{Binding Value}"
                                              SelectedValue="{Binding Region}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:ShippingRegion">
                                                <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Column="2" Margin="0,0,8,0" MinWidth="100"
                                              ItemsSource="{Binding $parent[ItemsControl].((vm:DraftDetailViewModel)DataContext).RuralOptions}"
                                              SelectedItem="{Binding Rural}"/>
                                    <CheckBox Grid.Column="3" Content="Signed" VerticalAlignment="Center"
                                              IsChecked="{Binding Signed}"/>
                                    <Button Grid.Column="4" Margin="8,0,0,0"
                                            Background="Transparent"
                                            ToolTip.Tip="Remove this option"
                                            Command="{Binding $parent[ItemsControl].((vm:DraftDetailViewModel)DataContext).RemoveShippingOptionCommand}"
                                            CommandParameter="{Binding}">
                                        <mi:MaterialIcon Kind="Delete" Width="18" Height="18"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding AddShippingOptionCommand}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                            <TextBlock Text="Add shipping option"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Text="Pickup (required)" Classes="label"/>
                <ComboBox ItemsSource="{Binding PickupOptions}"
                          SelectedItem="{Binding Listing.PickupOption}"
                          HorizontalAlignment="Left" MinWidth="160"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
