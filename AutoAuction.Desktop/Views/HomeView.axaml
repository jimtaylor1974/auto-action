<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoAuction.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AutoAuction.Desktop.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             DragDrop.AllowDrop="True">

    <Grid ColumnDefinitions="320,Auto,*">

        <!-- ===== Inbox gallery ===== -->
        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Inbox header -->
                <StackPanel Grid.Row="0" Margin="12,12,12,4" Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <mi:MaterialIcon Grid.Column="0" Kind="Inbox" Width="20" Height="20"
                                         VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Inbox" FontSize="16" FontWeight="SemiBold"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Click="OnAddPhotosClick"
                                ToolTip.Tip="Add photos from your computer"
                                Padding="6,4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="ImagePlus" Width="16" Height="16"/>
                                <TextBlock Text="Add" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Command="{Binding OpenInboxFolderCommand}"
                                ToolTip.Tip="Open the inbox folder in your file manager"
                                Padding="4" Background="Transparent" Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                        </Button>
                        <Button Grid.Column="4" Command="{Binding RefreshInboxCommand}"
                                ToolTip.Tip="Rescan the inbox folder"
                                Padding="4" Background="Transparent" Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="Drag photos here or click Add, then tick the ones to turn into a draft."
                               FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>
                </StackPanel>

                <!-- Inbox thumbnails -->
                <ScrollViewer Grid.Row="1" Padding="12,4">
                    <ItemsControl ItemsSource="{Binding InboxImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InboxImageViewModel">
                                <Border Margin="4" Padding="2" CornerRadius="4"
                                        BorderThickness="3" BorderBrush="Transparent"
                                        Classes.thumbSelected="{Binding IsSelected}">
                                    <StackPanel Width="92">
                                        <Border CornerRadius="3" ClipToBounds="True"
                                                Height="92" Background="#22000000">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <CheckBox Content="{Binding FileName}"
                                                  IsChecked="{Binding IsSelected}"
                                                  FontSize="10" Margin="0,2,0,0"
                                                  MaxWidth="92"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1" Text="No photos in the inbox yet."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.5" FontSize="12"
                           IsVisible="{Binding !InboxImages.Count}"/>

                <!-- Create Draft button -->
                <Button Grid.Row="2" Margin="12,4,12,12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding CreateDraftCommand}"
                        Classes="accent">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="PlusBox" Width="18" Height="18"/>
                        <TextBlock Text="Create Draft from selected"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"
                      Background="Transparent" HorizontalAlignment="Stretch"/>

        <!-- ===== Drafts table ===== -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*" Margin="16,12">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <mi:MaterialIcon Kind="FileDocumentEdit" Width="20" Height="20"/>
                <TextBlock Text="Drafts" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Drafts}"
                      SelectedItem="{Binding SelectedDraft}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      DoubleTapped="OnDraftDoubleTapped">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="56">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DraftListItemViewModel">
                                <Border Width="40" Height="40" CornerRadius="3" Margin="6,4"
                                        ClipToBounds="True" Background="#22000000">
                                    <Image Source="{Binding CoverThumbnail}" Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Title" Binding="{Binding DisplayTitle}" Width="*"/>
                    <DataGridTextColumn Header="Photos" Binding="{Binding PhotoCount}" Width="80"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedDisplay}" Width="150"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="1" Text="No drafts yet. Select inbox photos and click Create Draft."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0.5" FontSize="12"
                       IsVisible="{Binding !Drafts.Count}"/>
        </Grid>
    </Grid>
</UserControl>
