<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoAuction.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AutoAuction.Desktop.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             DragDrop.AllowDrop="True">

    <Grid>

        <!-- ===== Inbox gallery ===== -->
        <Border Grid.Column="0">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Inbox header -->
                <StackPanel Grid.Row="0" Margin="12,12,12,4" Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                        <mi:MaterialIcon Grid.Column="0" Kind="Inbox" Width="20" Height="20"
                                         VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Inbox" FontSize="16" FontWeight="SemiBold"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Click="OnGrabFromCloudClick"
                                IsVisible="{Binding HasCloudFolder}"
                                ToolTip.Tip="{Binding CloudButtonLabel}"
                                Padding="6,4" Margin="0,0,4,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="Cloud" Width="16" Height="16"/>
                                <TextBlock Text="Cloud" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Click="OnAddPhotosClick"
                                ToolTip.Tip="Add photos from your computer"
                                Padding="6,4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="ImagePlus" Width="16" Height="16"/>
                                <TextBlock Text="Add" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4" Command="{Binding OpenInboxFolderCommand}"
                                ToolTip.Tip="Open the inbox folder in your file manager"
                                Padding="4" Background="Transparent" Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                        </Button>
                        <Button Grid.Column="5" Command="{Binding RefreshInboxCommand}"
                                ToolTip.Tip="Rescan the inbox folder"
                                Padding="4" Background="Transparent" Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="Drag photos here or click Add, then tick the ones to turn into a draft."
                               FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>
                </StackPanel>

                <!-- Inbox thumbnails -->
                <ScrollViewer Grid.Row="1" Padding="12,4">
                    <ItemsControl ItemsSource="{Binding InboxImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InboxImageViewModel">
                                <Border Margin="4" Padding="2" CornerRadius="4"
                                        BorderThickness="3" BorderBrush="Transparent"
                                        Classes.thumbSelected="{Binding IsSelected}">
                                    <StackPanel Width="92">
                                        <Border CornerRadius="3" ClipToBounds="True"
                                                Height="92" Background="#22000000">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <CheckBox Content="{Binding FileName}"
                                                  IsChecked="{Binding IsSelected}"
                                                  FontSize="10" Margin="0,2,0,0"
                                                  MaxWidth="92"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1" Text="No photos in the inbox yet."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.5" FontSize="12"
                           IsVisible="{Binding !InboxImages.Count}"/>

                <!-- Create buttons: choose one multi-photo listing, or one listing per photo -->
                <StackPanel Grid.Row="2" Margin="12,4,12,12" Spacing="6">
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding CreateOneListingCommand}" Classes="accent">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="PlusBox" Width="18" Height="18"/>
                            <TextBlock Text="{Binding CreateOneListingText}"/>
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding CreatePerPhotoCommand}"
                            IsVisible="{Binding ShowPerPhoto}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="ImageMultiple" Width="18" Height="18"/>
                            <TextBlock Text="{Binding CreatePerPhotoText}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
