<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoAuction.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="AutoAuction.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AutoAuction"
        Width="1200" Height="800"
        MinWidth="950" MinHeight="600">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top menu -->
        <Menu Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Home" Command="{Binding NavigateToHomeCommand}"/>
                <MenuItem Header="_Listed" Command="{Binding NavigateToListedCommand}"/>
                <MenuItem Header="_Settings" Command="{Binding NavigateToSettingsCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Body: left nav rail + content -->
        <Grid Grid.Row="1" ColumnDefinitions="90,*">
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0" Spacing="2">
                    <Button Command="{Binding NavigateToHomeCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="8,10" Background="Transparent"
                            Classes.selected="{Binding IsHomeSelected}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="Home" Width="24" Height="24"/>
                            <TextBlock Text="Home" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToListedCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="8,10" Background="Transparent"
                            Classes.selected="{Binding IsListedSelected}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="PackageVariantClosed" Width="24" Height="24"/>
                            <TextBlock Text="Listed" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToSettingsCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="8,10" Background="Transparent"
                            Classes.selected="{Binding IsSettingsSelected}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="Cog" Width="24" Height="24"/>
                            <TextBlock Text="Settings" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Active page -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"/>
        </Border>
    </Grid>
</Window>
