<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoAuction.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="AutoAuction.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="24,16">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left" Spacing="2" Margin="0,0,0,48">

            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <!-- ===== Local Bridge Server ===== -->
            <TextBlock Text="Local Bridge Server" Classes="section"/>
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="The Chrome extension fetches the active draft from this local server while you're on a TradeMe sell page."/>
                    <Grid ColumnDefinitions="Auto,Auto,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Port" Classes="label"/>
                            <NumericUpDown Value="{Binding ServerPort}" Minimum="1024" Maximum="65535"
                                           Increment="1" FormatString="0" MinWidth="140"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Bottom">
                            <TextBlock Text="URL" Classes="label"/>
                            <SelectableTextBlock Text="{Binding ServerUrl}" VerticalAlignment="Center"
                                                 Margin="0,0,0,8"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Find free port"
                                Command="{Binding FindFreePortCommand}" VerticalAlignment="Bottom"
                                Margin="0,0,0,4"/>
                    </Grid>
                    <CheckBox Content="Start the server automatically when the app launches"
                              IsChecked="{Binding ServerAutoStart}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Start" Command="{Binding StartServerCommand}"/>
                        <Button Content="Stop" Command="{Binding StopServerCommand}"/>
                        <TextBlock Text="{Binding ServerStatus}" VerticalAlignment="Center"
                                   Opacity="0.8" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== OpenAI ===== -->
            <TextBlock Text="OpenAI" Classes="section"/>
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="Listings are generated by calling the OpenAI Responses API directly. The key is encrypted at rest by your OS (Windows DPAPI / macOS Keychain / Linux keyring) — never stored in settings.json."/>

                    <TextBlock Text="API key" Classes="label"/>

                    <!-- A key is stored: show a masked placeholder + Change / Clear. -->
                    <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding ShowKeyMasked}"
                          ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="••••••••••••" IsReadOnly="True"
                                 IsTabStop="False" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Change key" Command="{Binding ChangeKeyCommand}"/>
                        <Button Grid.Column="2" Content="Clear" Command="{Binding ClearKeyCommand}"/>
                    </Grid>

                    <!-- No key, or replacing one: show an entry box + Save (+ Cancel when editing). -->
                    <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding ShowKeyEntry}"
                          ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding NewKey}" PasswordChar="•"
                                 Watermark="sk-…" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Save key" Command="{Binding SaveKeyCommand}"
                                Classes="accent"/>
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelKeyEditCommand}"
                                IsVisible="{Binding CanCancelKeyEdit}"/>
                    </Grid>

                    <TextBlock Text="Model" Classes="label"/>
                    <TextBox Text="{Binding OpenAiModel}" Watermark="e.g. gpt-4o" MaxWidth="240"
                             HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                        <Button Content="Test connection" Command="{Binding TestCommand}"/>
                        <TextBlock Text="{Binding TestResult}" TextWrapping="Wrap" FontSize="12"
                                   Opacity="0.85" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== TradeMe Categories ===== -->
            <TextBlock Text="TradeMe Categories" Classes="section"/>
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="Downloads the full TradeMe category tree from their public catalogue API and caches it as categories.json in the app folder. Used for AI prompts and to match categories during listing automation. Refresh if TradeMe changes their categories."/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding FetchCategoriesCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="CloudDownload" Width="16" Height="16"/>
                                <TextBlock Text="Fetch / refresh categories" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding CategoriesStatus}" VerticalAlignment="Center"
                                   Opacity="0.85" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Quick import folder ===== -->
            <TextBlock Text="Quick import folder" Classes="section"/>
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="Point this at a folder your phone syncs photos into — e.g. iCloud Photos, OneDrive, Dropbox or Google Drive. Once set, a cloud button appears on the Inbox so you can grab photos straight from there."/>

                    <TextBlock Text="Folder" Classes="label"/>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding CloudPhotosPath}"
                                 Watermark="Not set — choose a folder, then Save settings"
                                 VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Click="OnBrowseCloudFolderClick">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="FolderSearch" Width="16" Height="16"/>
                                <TextBlock Text="Browse…" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Content="Clear" Command="{Binding ClearCloudFolderCommand}"/>
                    </Grid>

                    <!-- Auto-detected suggestion (offered, not applied until you Save) -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          IsVisible="{Binding ShowDetectedSuggestion}">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Detected on this PC:" FontSize="11" Opacity="0.7"/>
                            <SelectableTextBlock Text="{Binding DetectedCloudFolder}" FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Use this" Command="{Binding UseDetectedFolderCommand}"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Button label (optional)" Classes="label"/>
                    <TextBox Text="{Binding CloudPhotosLabel}" Watermark="e.g. OneDrive"
                             MaxWidth="240" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ===== General ===== -->
            <TextBlock Text="General" Classes="section"/>
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Text="App data folder" Classes="label"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <SelectableTextBlock Grid.Column="0" Text="{Binding RootPath}"
                                             VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding OpenRootFolderCommand}" Padding="6,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                                <TextBlock Text="Open" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Save ===== -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button Content="Save settings" Command="{Binding SaveCommand}" Classes="accent"/>
                <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center" Opacity="0.75" FontSize="12"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
